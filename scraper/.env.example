# Google Custom Search API (free, 100 queries/day)
# Get from: console.cloud.google.com → Enable Custom Search API → Credentials
GOOGLE_CSE_KEY=your-api-key
# Get from: programmablesearchengine.google.com → Create → set "Search entire web" → Copy CX
GOOGLE_CSE_CX=your-search-engine-id

# Claude API (script generation)
ANTHROPIC_API_KEY=sk-ant-...

# Mode: "mock" uses cached fixtures, "live" hits real APIs
SCRAPER_MODE=mock

# Markets to scrape (comma-separated city:state:zip)
MARKETS=Cape Coral:FL:33914,Fort Myers:FL:33901,Naples:FL:34102,Lehigh Acres:FL:33936
