# ============================================
# GarutiApp Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# The app works with mock data even without API keys.
# Add keys to enable live data.
# ============================================

# --- REQUIRED (for auth/database) ---
# Get from: Supabase → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- OPTIONAL (for live content discovery) ---
# Without these, the app uses realistic mock data for demos.

# Google Custom Search — content discovery across all platforms
# Get from: console.cloud.google.com → Enable Custom Search API → Credentials
# Free: 100 queries/day
GOOGLE_CUSTOM_SEARCH_KEY=your-key
# Get from: programmablesearchengine.google.com → Create → Copy CX ID
GOOGLE_CUSTOM_SEARCH_CX=your-search-engine-id

# Google Gemini AI — generates 5 script adaptations per post
# Get from: aistudio.google.com → Get API Key
# Free: 15 req/min, 1M tokens/day
GEMINI_API_KEY=your-key

# YouTube Data API v3 — video engagement stats (views, likes, comments)
# Get from: console.cloud.google.com → Enable YouTube Data API v3 → Credentials
# Free: 10,000 units/day
YOUTUBE_API_KEY=your-key

# Twitter/X API v2 — tweet engagement stats (likes, retweets, replies)
# Get from: developer.twitter.com → Create Project → Bearer Token
# Free: 1,500 tweet reads/month
TWITTER_BEARER_TOKEN=your-token

# --- OPTIONAL (for payments — Phase 5) ---
# Get from: stripe.com → Developers → API Keys
# Free to set up, you only pay 2.9% + $0.30 per transaction
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Server-side only (use in Supabase Edge Functions, NEVER in client code):
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# --- OPTIONAL (for email sequences — Phase 6) ---
# Get from: resend.com → API Keys
# Free: 100 emails/day
RESEND_API_KEY=re_...

# --- FUTURE (upgrade path) ---

# Anthropic Claude AI — premium adaptation quality (upgrade from Gemini)
# ANTHROPIC_API_KEY=sk-ant-...          (for when revenue justifies $5-150/mo)
